/* Hide the actual file input */
.file-input-hidden {
    width: 0.1px;
    height: 0.1px;
    opacity: 0;
    overflow: hidden;
    position: absolute;
    z-index: -1;
}

/* Style the label as the 'Button' */
.custom-file-upload {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 20px;
    background: rgba(15, 23, 42, 0.5);
    border: 2px dashed var(--border);
    border-radius: 8px;
    color: var(--accent);
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9rem;
    text-align: center;
}

.custom-file-upload:hover {
    border-color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    color: var(--text);
}

/* Add a class for when a file is selected to show success */
.file-selected {
    border-color: #10b981 !important; /* Green */
    color: #10b981 !important;
}

.file-name-display {
    display: block;
    margin-top: 5px;
    font-size: 0.75rem;
    color: var(--primary);
    font-style: italic;
}


<div class="upload-group">
    <label>First DataFrame (CSV/Excel)</label>
    <input type="file" id="file1" name="file1" accept=".csv, .xlsx" class="file-input-hidden" required>
    <label for="file1" class="custom-file-upload" id="label-file1">
        <span>📁 Choose a file...</span>
    </label>
    <span id="name-file1" class="file-name-display"></span>
</div>

<div id="sheet-selector-container">
    </div>

<div class="upload-group file2-group">
    <label>Second DataFrame (CSV)</label>
    <input type="file" id="file2" name="file2" accept=".csv" class="file-input-hidden" required>
    <label for="file2" class="custom-file-upload" id="label-file2">
        <span>📁 Choose a file...</span>
    </label>
    <span id="name-file2" class="file-name-display"></span>
</div>


// Function to update the UI when a file is selected
function handleFileSelection(inputId, labelId, nameId) {
    const input = document.getElementById(inputId);
    const label = document.getElementById(labelId);
    const nameDisplay = document.getElementById(nameId);

    input.addEventListener('change', function(e) {
        const fileName = e.target.files[0] ? e.target.files[0].name : "Choose a file...";
        
        if (e.target.files[0]) {
            label.classList.add('file-selected');
            label.innerHTML = '<span>✅ File Selected</span>';
            nameDisplay.textContent = fileName;
        } else {
            label.classList.remove('file-selected');
            label.innerHTML = '<span>📁 Choose a file...</span>';
            nameDisplay.textContent = '';
        }
    });
}

// Initialize for both inputs
handleFileSelection('file1', 'label-file1', 'name-file1');
handleFileSelection('file2', 'label-file2', 'name-file2');
